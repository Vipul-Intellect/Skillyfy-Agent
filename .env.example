# Google Cloud Project
GOOGLE_CLOUD_PROJECT=multi-agent-492316

# Gemini API (from AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key_here

# RapidAPI (for JSearch only)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_JSEARCH_HOST=jsearch.p.rapidapi.com

# Cloud Run executor service
EXECUTOR_SERVICE_URL=https://your-executor-service.run.app
EXECUTOR_SHARED_SECRET=your_shared_secret_here
EXECUTOR_REQUEST_TIMEOUT=20

# Legacy local fallback executor setting
PISTON_API_URL=https://emkc.org/api/v2/piston/execute

# Flask Configuration
FLASK_ENV=production
FLASK_SECRET_KEY=replace_with_a_long_random_secret
FLASK_DEBUG=False

# Cache Settings (hours)
TRENDING_CACHE_TTL=24
VIDEO_CACHE_TTL=12
JOB_CACHE_TTL=6
MARKET_PROFILE_CACHE_TTL_MINUTES=15
ENABLE_MARKET_PROFILE_PREWARM=False
ENABLE_AGENT1_STARTUP_WARMUP=False

# Timeouts (seconds)
API_TIMEOUT=30
